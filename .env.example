# Brain Spa — copy to .env for local overrides (optional).
# Runtime state and secrets default to ~/.brain-spa unless BRAIN_SPA_HOME is set.

# Where Brain Spa stores state, artifacts, and secrets
# BRAIN_SPA_HOME=~/.brain-spa

# Frontend → API (default http://127.0.0.1:8000)
# VITE_BACKEND_URL=http://127.0.0.1:8000

# API bind (defaults: 127.0.0.1:8000)
# BRAIN_SPA_API_HOST=127.0.0.1
# BRAIN_SPA_API_PORT=8000

# Comma-separated CORS origins for the Vite dev server
# BRAIN_SPA_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# xAI / Grok — Chipmunk voice and Evidence web mining (optional; UI works without)
# XAI_API_KEY=xai-...

# Disable Telegram long-polling (recommended for CI and dev without bots)
# BRAIN_SPA_DISABLE_TELEGRAM_POLLING=1

# Hugging Face — only if you use gated models
# HF_TOKEN=hf_...
