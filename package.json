{
  "name": "brain-spa",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Balllvin/brain-spa-local-ai.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api": "python3 -m apps.api.brainspa_api",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:api": "BRAIN_SPA_DISABLE_TELEGRAM_POLLING=1 python3 -m pytest apps/api/tests -q",
    "verify": "npm run build && npm run test:api"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.4.1",
    "playwright": "^1.60.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
